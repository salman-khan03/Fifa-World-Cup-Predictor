# ---- Sports data: football-data.org (free) ----
# Register at https://www.football-data.org/client/register
FOOTBALL_DATA_API_TOKEN=

# ---- Sports data: api-football / api-sports.io (free, 100 req/day) ----
# Register at https://api-sports.io
API_FOOTBALL_KEY=

# ---- Groq — AI text streaming (free tier) ----
# Get key at https://console.groq.com
VITE_GROQ_API_KEY=

# ---- Pollinations.ai — image & text generation ----
# Optional — app works without a key (free public URLs)
# Get key at https://enter.pollinations.ai
VITE_POLLINATIONS_KEY=

# ---- Gemini — optional image generation fallback ----
# Get key at https://aistudio.google.com/apikey (needs AIza... format)
VITE_GEMINI_API_KEY=
VITE_GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp

# ---- Supabase — auth + database (free tier) ----
# Create project at https://supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=

# ---- Hugging Face — optional ----
# Get token at https://huggingface.co/settings/tokens
VITE_HF_TOKEN=
