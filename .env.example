# ---- Sports data: football-data.org (free) ----
FOOTBALL_DATA_API_TOKEN=

# ---- Sports data: api-football / api-sports.io ----
API_FOOTBALL_KEY=

# ---- Groq — AI text streaming ----
GROQ_API_KEY=
VITE_GROQ_API_KEY=

# ---- Pollinations.ai — image & text (key optional; free without) ----
VITE_POLLINATIONS_KEY=

# ---- Gemini — optional image generation ----
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-preview-image-generation
VITE_GEMINI_API_KEY=
VITE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-preview-image-generation

# ---- Supabase — auth + database ----
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=

# ============================================================================
#  Stripe — subscriptions & one-time passes (SERVER-SIDE ONLY, no VITE_ prefix)
#  Read by the serverless functions in /api. Never ship these to the browser.
# ============================================================================
STRIPE_SECRET_KEY=             # sk_test_… / sk_live_…  (dashboard.stripe.com/apikeys)
STRIPE_WEBHOOK_SECRET=         # whsec_…  (Developers → Webhooks)
STRIPE_PRICE_PRO_MONTHLY=      # price_…  recurring $4.99/mo
STRIPE_PRICE_TOURNAMENT=       # price_…  one-time $9.99
STRIPE_PRICE_FOUNDER=          # price_…  one-time $6.99 launch

# Server copy of Supabase creds for /api (service_role bypasses RLS — SERVER ONLY)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=